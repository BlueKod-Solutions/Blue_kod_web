# ─────────────────────────────────────────────
#  BlueKod Backend – Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://localhost:27017/bluekod
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/bluekod
MONGODB_URI=mongodb+srv://Bluekod_db_user:6rSScYPw8ikFZiz7@cluster1.esaphb8.mongodb.net/?appName=Cluster1

# CORS – comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Optional: Rate limiting (requests per 15 min window per IP)
RATE_LIMIT_MAX=100
